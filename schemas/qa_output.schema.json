{
  "description": "ChatGPT Web QA output. Local validate-model-outputs performs authoritative checks before apply-qa.",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "job_id", "document_id", "status", "findings"],
  "properties": {
    "schema_version": {"type": "string"},
    "job_id": {"type": "string"},
    "document_id": {"type": "string"},
    "status": {"type": "string", "const": "complete"},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "severity", "issue", "apply"],
        "properties": {
          "item_id": {"type": "string"},
          "cell_id": {"type": "string"},
          "severity": {"type": "string"},
          "issue": {"type": "string"},
          "suggested_translation": {"type": ["string", "null"]},
          "apply": {"type": "boolean"}
        },
        "additionalProperties": true
      }
    },
    "document_level_notes": {"type": "array"}
  }
}
